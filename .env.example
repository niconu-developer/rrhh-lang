PLANNER_HOST=0.0.0.0
PLANNER_PORT=8765
PLANNER_PUBLIC_PORT=8766
PLANNER_BASE_PATH=/rrhh
PLANNER_PUBLIC_BASE_URL=https://app.lang.uy/rrhh
POSTGRES_DB=lang_rrhh
POSTGRES_USER=lang_rrhh
POSTGRES_PASSWORD=cambiar-esta-clave-postgres
DATABASE_URL=postgresql://lang_rrhh:cambiar-esta-clave-postgres@rrhh-db:5432/lang_rrhh
PLANNER_FRONTEND_DIR=/app/frontend
PLANNER_SERVE_STATIC=1

# Mantener apagado en produccion con datos reales.
# Si se prende, carga/actualiza datos semilla de demo desde backend/seed*.sql.
PLANNER_RUN_DATA_SEED=0

# Cambiar antes de subir a un entorno expuesto.
PLANNER_ADMIN_PASSWORD=cambiar-esta-clave-admin
PLANNER_FIRST_ACCESS_SECURITY_CODE=LANG

# Sesiones de API.
PLANNER_SESSION_TTL_HOURS=12
PLANNER_ACCESS_LINK_TTL_HOURS=48
PLANNER_PASSWORD_ITERATIONS=260000

# API externa de solo lectura para integraciones.
# Usar header: X-API-Key: <valor>
PLANNER_INTEGRATION_API_KEY=cambiar-esta-clave-integracion

# SSO opcional contra la app principal.
# Si queda vacio, se usa solo el login local de RRHH.
PLANNER_EXTERNAL_AUTH_ME_URL=
PLANNER_EXTERNAL_AUTH_COOKIE_NAME=connect.sid
PLANNER_EXTERNAL_AUTH_TIMEOUT_SECONDS=3
PLANNER_EXTERNAL_AUTH_DEBUG=0
PLANNER_EXTERNAL_AUTH_ALLOW_COOKIELESS=0
